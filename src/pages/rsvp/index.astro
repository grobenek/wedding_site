---
// ============================================================
// Web3Forms access key — public by design, safe to hardcode.
// ============================================================
const WEB3FORMS_KEY = 'e0cfa643-75e6-49db-8505-df89ccff1f2f';

import Layout from '../../layouts/Layout.astro';
---

<Layout title="RSVP · Svadba">
  <div class="page">
    <p class="label">Potvrdiť účasť</p>
    <h1 class="page-title">RSVP</h1>

    <p class="rsvp-intro">
      Prosíme o potvrdenie Vašej účasti do <strong>1. februára 2027</strong>.
    </p>

    <p id="no-token-notice" class="form-notice" hidden>
      Nepoznáme vás z QR kódu. Do poľa nižšie prosím vypíšte mená všetkých, ktorí prídu (oddelené čiarkou), aby sme vašu odpoveď vedeli správne priradiť. Ak máte problém, napíšte nám na <a class="email-link" href="mailto:peter.szathmary@szathmary.sk">peter.szathmary@szathmary.sk</a>.
    </p>

    <form id="rsvp-form" novalidate>
      <!-- Web3Forms required field -->
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />

      <!-- Optional but recommended: custom subject line for notification emails -->
      <input type="hidden" name="subject" value="Nová RSVP odpoveď svadba" />

      <!-- Honeypot spam trap (Web3Forms convention: must be named exactly this) -->
      <input type="checkbox" name="botcheck" id="botcheck" style="display: none;" />

      <!-- Email from value -->
      <input type="hidden" name="from_name" value="Svadobný organizátor">

      <!-- Hidden: tracking token from QR code -->
      <input type="hidden" name="token" id="token" value="direct" />

      <!-- Guests: free-text fallback when no known guest list (no token / no-guests param) -->
      <div class="field conditional" id="name-field">
        <label for="name">Vaše meno (a mená ďalších, ak prídete viacerí)</label>
        <input
          type="text"
          id="name"
          name="name"
          autocomplete="name"
          placeholder="Jana Nováková, Peter Novák"
        />
      </div>

      <!-- Attending -->
      <fieldset class="field">
        <legend class="field-legend">Zúčastníte sa?</legend>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="attending" value="yes" required />
            Áno, prídem s radosťou
          </label>
          <label class="radio-label">
            <input type="radio" name="attending" value="no" />
            Ľutujem, nemôžem sa zúčastniť
          </label>
        </div>
      </fieldset>

      <!-- Guests: checkbox list when invited via QR with known names — shown once attending = yes -->
      <fieldset class="field conditional" id="guests-field" hidden>
        <legend class="field-legend">Kto z vás príde?</legend>
        <div class="radio-group" id="guests-checklist"></div>
      </fieldset>

      <div class="field conditional" id="night-field" hidden>
        <fieldset>
          <legend class="field-legend">Zostanete cez noc?</legend>
          <p class="field-hint">Ubytovanie je k dispozícii priamo na mieste</p>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="night_yn" id="night-yes" value="yes" />
              Áno, zostaneme cez noc
            </label>
            <label class="radio-label">
              <input type="radio" name="night_yn" id="night-no" value="no" />
              Nie, ďakujem
            </label>
          </div>
        </fieldset>

        <fieldset class="conditional" id="night-checklist-fieldset" hidden>
          <legend class="field-legend">Kto z vás zostane cez noc?</legend>
          <div class="radio-group" id="night-checklist"></div>
        </fieldset>
      </div>

      <!-- Optional message -->
      <div class="field">
        <label for="message">Správa <span class="optional">(voliteľné)</span></label>
        <textarea
          id="message"
          name="message"
          rows="3"
          placeholder="Tešíme sa na Vás..."
        ></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary" id="submit-btn">
          Potvrdiť
        </button>
      </div>

      <p class="form-error" id="form-error" hidden>
        Nastala chyba. Skúste to prosím znovu, alebo nás kontaktujte priamo.
      </p>
    </form>
  </div>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);

    // ── Pre-fill from QR code URL ──────────────────────────
    const tokenInput = document.getElementById('token');
    const nameInput  = document.getElementById('name');
    const form       = document.getElementById('rsvp-form');

    const rawToken = params.get('id') || 'direct';
    tokenInput.value = rawToken;
    const isTokenPresent = rawToken !== 'direct';
    if (!isTokenPresent) {
      document.getElementById('no-token-notice').hidden = false;
    }

    // ── Guests: parse "guests" param into a named checkbox list ────
    const rawGuests = params.get('guests');
    const guestNames = rawGuests
      ? decodeURIComponent(rawGuests).split(',').map(s => s.trim()).filter(Boolean)
      : [];
    const hasGuestList = guestNames.length > 0;

    const guestsField     = document.getElementById('guests-field');
    const guestsChecklist = document.getElementById('guests-checklist');
    const nameField       = document.getElementById('name-field');

    if (hasGuestList) {
      // Checkbox-list mode: known household, render one checkbox per guest.
      guestNames.forEach((guestName, i) => {
        const id = `guest-${i}`;
        const label = document.createElement('label');
        label.className = 'radio-label';
        label.innerHTML = `<input type="checkbox" id="${id}" data-guest-name="${guestName.replace(/"/g, '&quot;')}" /> ${guestName}`;
        guestsChecklist.appendChild(label);
      });
      guestsField.hidden = true; // revealed once attending = yes (see updateConditionalFields)
      nameField.hidden = true;
      nameInput.removeAttribute('required');
    } else {
      // Free-text fallback: no known guest list (no token, or token without guests param).
      nameField.hidden = false;
      nameInput.setAttribute('required', '');

      // Backward-compat: still honor a plain "name" param to pre-fill the free-text field.
      const rawName = params.get('name');
      if (rawName) nameInput.value = decodeURIComponent(rawName);
    }

    const allowNight = params.get('n') === '1';
    const nightField           = document.getElementById('night-field');
    const nightChecklistFs     = document.getElementById('night-checklist-fieldset');
    const nightChecklist       = document.getElementById('night-checklist');
    const nightYesRadio        = document.getElementById('night-yes');
    const nightNoRadio         = document.getElementById('night-no');

    // ── Rebuild the night-stay checklist from the currently attending guests ──
    function rebuildNightChecklist() {
      if (!hasGuestList) return;
      const attendingNames = Array.from(guestsChecklist.querySelectorAll('input:checked'))
        .map(i => i.dataset.guestName);

      // Preserve existing night selections across rebuilds (for names still attending)
      const previouslyChecked = new Set(
        Array.from(nightChecklist.querySelectorAll('input:checked')).map(i => i.dataset.guestName)
      );
      const hasExistingState = nightChecklist.querySelectorAll('input').length > 0;

      nightChecklist.innerHTML = '';
      attendingNames.forEach((guestName, i) => {
        const label = document.createElement('label');
        label.className = 'radio-label';
        const wasChecked = hasExistingState
          ? previouslyChecked.has(guestName)
          : true; // default: everyone currently attending is checked on first render
        const checkedAttr = wasChecked ? 'checked' : '';
        label.innerHTML = `<input type="checkbox" id="night-guest-${i}" data-guest-name="${guestName.replace(/"/g, '&quot;')}" ${checkedAttr} /> ${guestName}`;
        nightChecklist.appendChild(label);
      });
    }

    // ── Show/hide the names checklist based on the yes/no night answer ────
    function updateNightChecklist() {
      if (!hasGuestList) return;
      const showChecklist = nightYesRadio.checked;
      nightChecklistFs.hidden = !showChecklist;
      if (showChecklist) {
        rebuildNightChecklist();
      } else {
        nightChecklist.querySelectorAll('input').forEach(i => i.checked = false);
      }
    }

    if (hasGuestList) {
      nightYesRadio.addEventListener('change', updateNightChecklist);
      nightNoRadio.addEventListener('change', updateNightChecklist);

      // Keep the night checklist in sync whenever attending-guest checkboxes change,
      // so unchecking someone from attending also drops them from overnight stay.
      guestsChecklist.addEventListener('change', () => {
        if (!nightChecklistFs.hidden) rebuildNightChecklist();
      });
    }

    // ── Show/hide conditional fields based on attending ────
    function updateConditionalFields() {
      const checkedAttending = form.querySelector('input[name="attending"]:checked');
      const isYes = checkedAttending ? checkedAttending.value === 'yes' : false;

      if (hasGuestList) {
        guestsField.hidden = !isYes;
        if (guestsField.hidden) {
          guestsChecklist.querySelectorAll('input').forEach(i => i.checked = false);
        }
      }

      // No token: show night field whenever attending = yes, ignoring n param entirely.
      // With a token: only show if the URL param explicitly allowed it AND attending = yes.
      const showNight = isTokenPresent ? (allowNight && isYes) : isYes;
      nightField.hidden = !showNight;

      if (nightField.hidden) {
        nightField.querySelectorAll('input').forEach(i => i.checked = false);
        if (hasGuestList) nightChecklistFs.hidden = true;
      }
    }

    const attendingRadios = document.querySelectorAll('input[name="attending"]');
    attendingRadios.forEach(radio => {
      radio.addEventListener('change', updateConditionalFields);
    });

    // Run once on load in case the browser auto-filled the radio buttons
    updateConditionalFields();

    // ── Form submission via fetch (no page redirect on POST) ─
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg  = document.getElementById('form-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const attending = form.querySelector('input[name="attending"]:checked');
      if (!attending) return;

      const attendingYes = attending.value === 'yes';

      let attendeesValue = '';
      if (hasGuestList) {
        const checked = Array.from(guestsChecklist.querySelectorAll('input:checked'))
          .map(i => i.dataset.guestName);
        // Require at least one selected guest when attending = yes.
        if (attendingYes && checked.length === 0) return;
        attendeesValue = checked.join(', ');
      } else {
        attendeesValue = nameInput.value.trim();
        if (!attendeesValue) return;
      }

      let nightValue = '';
      if (!nightField.hidden) {
        if (hasGuestList) {
          const nightAnswer = form.querySelector('input[name="night_yn"]:checked');
          if (nightAnswer && nightAnswer.value === 'yes') {
            const nightChecked = Array.from(nightChecklist.querySelectorAll('input:checked'))
              .map(i => i.dataset.guestName);
            nightValue = nightChecked.join(', ');
          } else if (nightAnswer && nightAnswer.value === 'no') {
            nightValue = 'no';
          }
        } else {
          const nightAnswer = form.querySelector('input[name="night_yn"]:checked');
          nightValue = nightAnswer ? nightAnswer.value : '';
        }
      }

      submitBtn.disabled    = true;
      submitBtn.textContent = 'Odosielam…';
      errorMsg.hidden       = true;

      try {
        const formData = new FormData(form);
        const object   = Object.fromEntries(formData);
        object.name    = attendeesValue; // unify both modes into a single "name" field for the email
        object.night   = nightValue; // radio renamed to night_yn, so this is set explicitly here
        const json     = JSON.stringify(object);

        const res = await fetch('https://api.web3forms.com/submit', {
          method:  'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept:         'application/json',
          },
          body: json,
        });

        const result = await res.json();

        if (res.ok && result.success) {
          window.location.href = '/rsvp/thanks';
        } else {
          throw new Error(result.message || 'Server error');
        }
      } catch {
        submitBtn.disabled    = false;
        submitBtn.textContent = 'Potvrdiť';
        errorMsg.hidden       = false;
      }
    });
  });
</script>

<style>
  .rsvp-intro {
    color: var(--c-muted);
    margin-bottom: var(--s-12);
    line-height: 1.7;
  }

  .form-notice {
    background: var(--c-surface-alt, rgba(0, 0, 0, 0.04));
    border-left: 3px solid var(--c-accent);
    padding: var(--s-3) var(--s-4);
    border-radius: 4px;
    font-size: var(--t-sm);
    color: var(--c-muted);
    line-height: 1.6;
    margin-bottom: var(--s-10);
  }

  #rsvp-form {
    margin-top: var(--s-4);
  }

  .field-hint {
    font-size: var(--t-sm);
    color: var(--c-muted);
    margin-bottom: var(--s-3);
  }

  .optional {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--c-muted);
    font-size: var(--t-xs);
  }

  .form-actions {
    margin-top: var(--s-8);
  }

  .email-link {
    color: var(--c-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .conditional {
    overflow: hidden;
  }

  .conditional[hidden] {
    display: none !important;
  }

  .conditional:not([hidden]) {
    animation: reveal 0.2s ease;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
