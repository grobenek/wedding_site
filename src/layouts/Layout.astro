---
import '../styles/global.css';

const COUPLE_A = 'Erika';
const COUPLE_B = 'Peter';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${COUPLE_A} & ${COUPLE_B}`,
  description = 'Svadobné oznámenie',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Keep the site off search engines -->
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Fonts: Fraunces (display) + Figtree (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=Figtree:wght@400;500&display=swap"
    rel="stylesheet"
  />

</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="nav-monogram">{COUPLE_A[0]} & {COUPLE_B[0]}</a>
      <div class="nav-links">
        <a href="/details">Informácie</a>
        <a href="/rsvp">RSVP</a>
        <!-- Uncomment when your Google Photos album is ready:
        <a href="/photos">Fotky</a>
        -->
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>{COUPLE_A} & {COUPLE_B}</p>
  </footer>
</body>
</html>
